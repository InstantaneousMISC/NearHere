// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  SUPER_ADMIN
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  SOLD_OUT
  CLOSED
  DESIGNING
  READY_FOR_PRINT
  PRINTING
  MAILED
  CANCELLED
}

enum PostcardSide {
  FRONT
  BACK
}

enum SpotType {
  PREMIUM
  LARGE
  STANDARD
  SMALL
}

enum SpotStatus {
  OPEN
  HELD
  SOLD
  UNAVAILABLE
}

enum OrderStatus {
  PENDING
  PAID
  REFUNDED
  CANCELLED
  EXPIRED
}

enum ApprovalStatus {
  PENDING
  NEEDS_REVIEW
  APPROVED
  REJECTED
  PRINTED
  MAILED
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model AdminUser {
  id             String   @id @default(cuid())
  supabaseUserId String   @unique
  email          String   @unique
  role           UserRole @default(ADMIN)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model BusinessCategory {
  id                       String         @id @default(cuid())
  name                     String
  slug                     String         @unique
  description              String?
  allowsMultipleAdvertisers Boolean       @default(false)
  defaultSpotType          SpotType       @default(STANDARD)
  defaultPrice             Int            @default(0) // in cents
  isActive                 Boolean        @default(true)
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  campaignSpots CampaignSpot[]
}

model Campaign {
  id                 String         @id @default(cuid())
  name               String
  slug               String
  city               String
  state              String
  county             String?
  zipCode            String?
  mailingQuantity    Int
  status             CampaignStatus @default(DRAFT)
  description        String?        @db.Text
  estimatedMailDate  DateTime?
  frontBackgroundUrl String?
  backBackgroundUrl  String?
  cardSize           String         @default("9x12")
  cardSkin           String         @default("cream")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  spots  CampaignSpot[]
  orders Order[]
  qrCodes QrCode[]

  @@unique([state, city, slug])
}

model CampaignSpot {
  id               String       @id @default(cuid())
  campaignId       String
  categoryId       String
  label            String
  side             PostcardSide
  spotType         SpotType     @default(STANDARD)
  price            Int          // in cents
  x                Float        // percentage 0-100
  y                Float        // percentage 0-100
  width            Float        // percentage 0-100
  height           Float        // percentage 0-100
  status           SpotStatus   @default(OPEN)
  heldUntil        DateTime?
  heldBySessionId  String?
  sortOrder        Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  campaign Campaign         @relation(fields: [campaignId], references: [id])
  category BusinessCategory @relation(fields: [categoryId], references: [id])
  orders   Order[]
  qrCodes  QrCode[]

  @@index([campaignId])
  @@index([categoryId])
}

model Advertiser {
  id              String   @id @default(cuid())
  contactName     String
  businessName    String
  email           String   @unique
  phone           String
  website         String?
  businessAddress String?
  heardAboutUs    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orders     Order[]
  businesses Business[]
}

model Order {
  id                       String      @id @default(cuid())
  campaignId               String
  campaignSpotId           String
  advertiserId             String
  status                   OrderStatus @default(PENDING)
  amount                   Int         // in cents
  stripeCheckoutSessionId  String?     @unique
  stripePaymentIntentId    String?
  creativeSubmissionToken  String      @unique
  paidAt                   DateTime?
  refundedAt               DateTime?
  refundReason             String?
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt

  campaign           Campaign            @relation(fields: [campaignId], references: [id])
  campaignSpot       CampaignSpot        @relation(fields: [campaignSpotId], references: [id])
  advertiser         Advertiser          @relation(fields: [advertiserId], references: [id])
  creativeSubmission CreativeSubmission?
  qrCodes            QrCode[]

  @@index([campaignId])
  @@index([campaignSpotId])
  @@index([advertiserId])
}

model CreativeSubmission {
  id               String         @id @default(cuid())
  orderId          String         @unique
  businessName     String?
  logoUrl          String?
  additionalImages Json?          // string[] of URLs
  headline         String?        @db.VarChar(80)
  offerDeal        String?        @db.VarChar(160)
  description      String?        @db.VarChar(300)
  cta              String?        @db.VarChar(60)
  phone            String?
  website          String?
  address          String?
  notes            String?        @db.VarChar(1000)
  wantsAiHelp      Boolean        @default(false)
  aiPrompt         String?        @db.Text
  approvalStatus   ApprovalStatus @default(PENDING)
  approvalNotes    String?
  submittedAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  order        Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reviewEvents CreativeReviewEvent[]
}

model CreativeReviewEvent {
  id                   String             @id @default(cuid())
  creativeSubmissionId String
  status               ApprovalStatus
  notes                String?            @db.Text
  adminEmail           String
  createdAt            DateTime           @default(now())

  creativeSubmission CreativeSubmission @relation(fields: [creativeSubmissionId], references: [id], onDelete: Cascade)

  @@index([creativeSubmissionId, createdAt])
}

model Lead {
  id           String   @id @default(cuid())
  businessName String?
  email        String
  zipCode      String
  campaignId   String?  // Optional: linked to campaign if joining waitlist
  categoryId   String?  // Optional: linked to category if joining waitlist
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── New Business & QR Models ───────────────────────────────────────────────

enum BusinessStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum BusinessLinkType {
  WEBSITE
  PHONE
  BOOKING
  FACEBOOK
  INSTAGRAM
  GOOGLE_MAPS
  MENU
  EMAIL
  CUSTOM
}

enum QrCodeStatus {
  ACTIVE
  EXPIRED
  DISABLED
}

enum QrCodeType {
  BUSINESS_PROFILE
  CAMPAIGN_SLOT
  OFFER
}

model Business {
  id              String         @id @default(cuid())
  advertiserId    String?
  ownerUserId      String?
  name            String
  slug            String         @unique
  description     String?        @db.Text
  phone           String?
  email           String?
  website         String?
  logoUrl         String?
  coverImageUrl   String?
  address         String?
  city            String?
  state           String?
  zipCode         String?
  status          BusinessStatus @default(DRAFT)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  claimToken          String?        @unique
  claimTokenExpiresAt DateTime?
  claimedAt           DateTime?


  advertiser      Advertiser?    @relation(fields: [advertiserId], references: [id])
  links           BusinessLink[]
  qrCodes         QrCode[]
  pageViews       BusinessPageView[]
  clickEvents     BusinessClickEvent[]

  @@index([advertiserId])
  @@index([ownerUserId])
}

model BusinessLink {
  id          String           @id @default(cuid())
  businessId  String
  type        BusinessLinkType
  label       String
  url         String
  sortOrder   Int              @default(0)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  business    Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model QrCode {
  id              String        @id @default(cuid())
  businessId      String
  campaignId      String?
  campaignSpotId  String?
  orderId         String?
  slug            String        @unique
  type            QrCodeType    @default(BUSINESS_PROFILE)
  status          QrCodeStatus  @default(ACTIVE)
  destinationPath String
  expiresAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  business        Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  campaign        Campaign?     @relation(fields: [campaignId], references: [id])
  campaignSpot    CampaignSpot? @relation(fields: [campaignSpotId], references: [id])
  order           Order?        @relation(fields: [orderId], references: [id])
  scans           QrScan[]

  @@index([businessId])
  @@index([campaignId])
  @@index([campaignSpotId])
  @@index([orderId])
  @@unique([orderId])
}

model QrScan {
  id              String    @id @default(cuid())
  qrCodeId        String
  businessId      String
  campaignId      String?
  campaignSpotId  String?
  scannedAt       DateTime  @default(now())
  userAgent       String?   @db.Text
  ipHash          String?
  referrer        String?
  deviceType      String?
  country         String?
  region          String?
  city            String?
  isExpiredScan   Boolean   @default(false)

  qrCode          QrCode    @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)

  @@index([qrCodeId])
  @@index([businessId])
  @@index([campaignId])
  @@index([campaignSpotId])
  @@index([scannedAt])
}

model BusinessPageView {
  id          String   @id @default(cuid())
  businessId  String
  qrCodeId    String?
  viewedAt    DateTime @default(now())
  userAgent   String?  @db.Text
  ipHash      String?

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([qrCodeId])
  @@index([viewedAt])
}

model BusinessClickEvent {
  id          String   @id @default(cuid())
  businessId  String
  qrCodeId    String?
  linkType    String
  linkLabel   String?
  targetUrl   String?  @db.Text
  clickedAt   DateTime @default(now())
  userAgent   String?  @db.Text
  ipHash      String?

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([qrCodeId])
  @@index([clickedAt])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  adminEmail String
  action     String
  businessId String?
  notes      String?  @db.Text
  metadata   Json?
  createdAt  DateTime @default(now())
}

model EmailLog {
  id          String      @id @default(cuid())
  toEmail     String
  templateKey String
  entityType  String
  entityId    String
  providerId  String?
  status      EmailStatus @default(PENDING)
  error       String?  @db.Text
  sentAt      DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([templateKey, entityType, entityId, toEmail])
  @@index([toEmail])
  @@index([entityType, entityId])
}
